table 'Datos de Entrega Amazon'
	lineageTag: a112a69b-b86c-4fa3-b3bd-35078dbf7cb2

	measure 'Pedidos Totales' = COUNT('Datos de Entrega Amazon'[ID_Pedido])
		formatString: 0
		lineageTag: 0305690d-b9e3-4cc5-9b34-21e65ce23d5f

		changedProperty = IsHidden

	measure 'Prom. Tiempo Entrega' =
			
			AVERAGEX(
			    FILTER(
			        'Datos de Entrega Amazon',
			        'Datos de Entrega Amazon'[Tiempo_Entrega] > 0
			    ),
			    'Datos de Entrega Amazon'[Tiempo_Entrega]
			)
		lineageTag: bd6ee2d3-1226-409d-817d-f5430c4c52a0

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Prom. Calificación Agente' =
			
			AVERAGE('Datos de Entrega Amazon'[Calificación_Agente])
		lineageTag: d5beac2b-7070-4846-89e6-017ec302fdf5

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Entrega tardía %' =
			
			DIVIDE(
			    COUNTROWS(
			        FILTER(
			            'Datos de Entrega Amazon',
			            'Datos de Entrega Amazon'[Entrega de Tardía] = "Late"
			        )
			    ),
			    COUNTROWS('Datos de Entrega Amazon')
			)
		lineageTag: 32e4dacf-805f-4c3e-8286-ce97dbc43de6

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Costo Total Estimado' =
			
			SUM('Datos de Entrega Amazon'[Tiempo_Entrega]) * 0.5
		lineageTag: 8974c267-c11f-4a2d-8b9a-41fbb673a245

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Prom. Costo Estimado' =
			
			AVERAGE('Datos de Entrega Amazon'[Tiempo_Entrega]) * 0.5
		lineageTag: 5eb81924-987b-4021-afe8-0f1d33f9751b

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Costo según el clima' =
			
			[Costo Total Estimado]
		lineageTag: 0fdbb2b0-85c0-4bdf-b393-c3c0eab5962d

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ingresos Totales' =
			
			COUNTROWS('Datos de Entrega Amazon') * 8
		formatString: 0
		lineageTag: 4b9cf6b9-0c75-447d-b8dd-69ac43aa2b6c

		changedProperty = IsHidden

	measure 'Venficio Total' =
			
			[Ingresos Totales] - [Costo Total Estimado]
		lineageTag: 4035fb03-5685-44a4-b25c-83d0ce6c1ad1

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Margen Veneficio %' =
			
			DIVIDE([Venficio Total], [Ingresos Totales])
		lineageTag: 6e091add-af00-44e3-a20d-feed65e3c715

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

