	column 'Entrega de Tardía' =
			
			IF ( [Tiempo_Entrega] > 40, "Late", "On Time" )
		lineageTag: 0bc82fa3-f7c7-4fef-84fb-f25e59687708
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column Tiempo_Preparación(min) =
			
			VAR Diff =
			    DATEDIFF(
			        'Datos de Entrega Amazon'[Hora_Pedido],
			        'Datos de Entrega Amazon'[Hora_Recogida],
			        MINUTE
			    )
			RETURN
			IF(Diff < 0, Diff + 1440, Diff)
		formatString: 0
		lineageTag: 310d4207-dc18-4af7-b74a-28f97311d5eb
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Hora del Pedido' =
			
			HOUR('Datos de Entrega Amazon'[Hora_Pedido])
		formatString: 0
		lineageTag: efe4d210-0e08-48c3-8930-0f35d44ee003
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column Segmento_Tiempo =
			
			IF(
			    'Datos de Entrega Amazon'[Hora del Pedido] >= 18 &&
			    'Datos de Entrega Amazon'[Hora del Pedido] <= 22,
			    "Peak",
			    "Off-Peak"
			)
		lineageTag: 8b078275-e1f3-4dc9-a2bb-df4dad532807
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

